# Ignore CSV data files globally.
*.csv
*.pkl
*.txt
*.parquet

# Processed and source datasets are local-only.
/Data/

# Operating-system metadata.
.DS_Store
Thumbs.db

# Python bytecode and tool caches.
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.ipynb_checkpoints/

# Generated analysis caches and reusable intermediates.
.cache/
cache/
intermediate/

# Local environments and secrets.
.env
.env.*
!.env.example
.venv/
venv/
env/
ENV/
conda-env/

# Editor-local settings.
.idea/
.vscode/
*.swp
*.swo
*~

# Keep generated PNG figures trackable throughout the repository.
!*.png
